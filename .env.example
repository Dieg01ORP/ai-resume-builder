# ============================================================
# ResumeAI — Variables de entorno
# Copia este archivo como .env.local y rellena tus valores
# NUNCA subas .env.local al repositorio
# ============================================================

# ── IA: Meta Llama 3.1 via Groq (GRATIS) ───────────────────
# Groq ofrece acceso gratuito a Llama 3.1-70B con límites generosos
# Consigue tu API key gratis en: https://console.groq.com
# 1. Crea cuenta en console.groq.com
# 2. Ve a "API Keys" → "Create API Key"
# 3. Pega la key aquí:
GROQ_API_KEY=gsk_tu_api_key_de_groq_aqui

# ── Opcional: Base de datos ─────────────────────────────────
# Si quieres persistencia en servidor (por defecto usa localStorage)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# ── Opcional: Analytics ─────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
